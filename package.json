{
  "name": "boardguard",
  "version": "0.2.0",
  "description": "Hardware design review, CI, and release preflight for KiCad projects.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "BoardGuard maintainers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka-lab/boardguard.git"
  },
  "bugs": {
    "url": "https://github.com/oaslananka-lab/boardguard/issues"
  },
  "homepage": "https://github.com/oaslananka-lab/boardguard#readme",
  "engines": {
    "node": ">=24 <27"
  },
  "packageManager": "pnpm@11.0.8",
  "bin": {
    "boardguard": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "action.yml"
  ],
  "scripts": {
    "format": "node scripts/format-check.mjs --write",
    "format:check": "node scripts/format-check.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "action:build": "node scripts/build-action.mjs",
    "fixtures": "vitest run tests/boardguard.test.ts --run",
    "scan:fixtures": "node scripts/validate-fixtures.mjs",
    "test": "vitest run",
    "security": "node scripts/lint.mjs --security",
    "release:dry-run": "node scripts/release-state.mjs --local"
  },
  "dependencies": {
    "@actions/artifact": "6.2.1",
    "@actions/github": "9.1.1",
    "yaml": "2.8.4"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "esbuild": "0.28.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
