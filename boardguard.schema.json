{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka-lab/boardguard/raw/main/boardguard.schema.json",
  "title": "BoardGuard configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "require_kicad_cli": { "type": "boolean" }
      }
    },
    "reports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "json": { "type": "boolean" },
        "sarif": { "type": "boolean" },
        "markdown": { "type": "boolean" }
      }
    },
    "manufacturing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "board_name": { "type": "string" },
        "revision": { "type": "string" },
        "output_dir": { "type": "string" },
        "expected_artifacts": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    },
    "bom": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input": { "type": "string" },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "firmware": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pinmap": { "type": "string" }
      }
    },
    "kicad": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "min_version": { "type": "string" },
        "drc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "severity": { "enum": ["all", "error", "warning"] },
            "schematic_parity": { "type": "boolean" },
            "refill_zones": { "type": "boolean" },
            "severity_exclusions": { "type": "boolean" }
          }
        },
        "erc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "severity": { "enum": ["all", "error", "warning"] },
            "severity_exclusions": { "type": "boolean" }
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "BG-CONFIG-001",
          "BG-PROJ-001",
          "BG-PROJ-002",
          "BG-PROJ-003",
          "BG-PROJ-004",
          "BG-IO-TOO-LARGE",
          "BG-KICAD-001",
          "BG-ERC-001",
          "BG-DRC-001",
          "BG-BOM-001",
          "BG-BOM-002",
          "BG-MFG-001",
          "BG-MFG-002",
          "BG-PIN-001"
        ]
      },
      "additionalProperties": {
        "enum": ["critical", "high", "medium", "low", "info", "error", "warning", "off"]
      }
    }
  }
}
